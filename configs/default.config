server {
    server_name example.com;

    listen 127.0.0.1:8080;

    root www/html;
    index index.html;
    client_max_body_size 5M;

    error_page 404 /errors/404.html;
    error_page 500 /errors/500.html;

    location / {
        allow_methods GET POST DELETE;
        autoindex off;
    }

    location /files {
        root www/html/files;
        autoindex on;
        index index.html;
        allow_methods GET DELETE;
    }

    location /old {
        return 301 /files;
    }

    location /kapouet {
        root www/html/kapouet;
        index index.html;
    }

    location /upload {
        root ./www/html/upload;
        index upload_form.html;
        allow_methods GET POST;
        upload on;
        upload_store ./www/html/files;
    }

    location /cgi-bin {
        index form.html
        allow_methods GET POST;
        root www/html/cgi-bin;
        cgi on;
        cgi_exec .py /usr/bin/python3;
        cgi_exec .sh /bin/bash;
    }
}
